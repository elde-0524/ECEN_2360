.global _start
_start:
	
	.global _start
_start:
	####
	# Example code to print the "Enter number:" prompt
	movia	r2, 0xff201000		# JTAG UART MMIO base address
    movia   r15, STR_PROMPT		# address of "Enter number:" string
	movia 	r18, STR_TOTAL		# address of "Total: " string
	
	# total entered
	mov r3, r0
	
write_str:
    ldb     r16, 0(r15)			# r16 = read next character from STR_PROMPT
    addi    r15, r15, 1			# advance pointer in STR_PROMPT
    beq     r16, r0, wait_num	# if we read null character, we're done

wait:
	ldwio	r17, 4(r2)			# read the control register to read WSPACE
	srli	r17, r17, 16		# get WSPACE
	beq		r17, r0, wait		# wait until there is space

    stwio   r16, 0(r2)			# write character (r16)
    br		write_str           # repeat for the next character
	
	# waits for the users number 
wait_num:
	ldwio r19, 0(r2) 			# read the user input
	andi r20, r19, 0xff
	srli r21, r19, 15
		
	beq r19, r0, wait_num		# wait until valid
	
wait_echo: 
	ldwio r17, 4(r2)
	srli r17, r17, 16 
	beq r6, r0, wait_echo		# if wpspace == 0, wait
	
	stwio r4, 0(r2)				# echo back the character
	
	add r3, r3, r20
	
write_str_total:
    ldb     r16, 0(r18)			# r16 = read next character from STR_PROMPT
    addi    r15, r15, 1			# advance pointer in STR_PROMPT
    beq     r16, r0, display_total		# if we read null character, we're done

wait_total:
	ldwio	r17, 4(r2)			# read the control register to read WSPACE
	srli	r17, r17, 16		# get WSPACE
	beq		r17, r0, wait_total		# wait until there is space

    stwio   r16, 0(r2)			# write character (r16)
    br		write_str_total     # repeat for the next character
	

display_total: 
	ldwio r17, 4(r2)
	srli r17, r17, 16 
	beq r6, r0, wait_echo		# if wpspace == 0, wait
	
	stwio r3, 0(r2)				# echo back the character
	

done:
	break

.data
STR_PROMPT: .string "Enter number:"
STR_TOTAL:  .string "Total:"
