.global _start
_start:
	####
	# Example code to print the "Enter number:" prompt
	movia	r2, 0xff201000		# JTAG UART MMIO base address
    movia   r15, STR_PROMPT		# address of "Enter number:" string
	movia 	r18, STR_TOTAL		# address of "Total: " string
	movia   sp, 0x007FFFFC
	
	mov r22, sp
	movi    r5, 0x0a
	movi r10, 10
	
	# total entered
	mov r3, r0
	
write_str:
    ldb     r16, 0(r15)			# r16 = read next character from STR_PROMPT
    addi    r15, r15, 1			# advance pointer in STR_PROMPT
    beq     r16, r0, wait_num	# if we read null character, we're done

wait:
	ldwio	r17, 4(r2)			# read the control register to read WSPACE
	srli	r17, r17, 16		# get WSPACE
	beq		r17, r0, wait		# wait until there is space

    stwio   r16, 0(r2)			# write character (r16)
    br		write_str           # repeat for the next character
	
	
wait_num:	# waits for the users number 
	ldwio r19, 0(r2) 			# read the user input
	andi r20, r19, 0xff
	srli r21, r19, 15
		
	beq r21, r0, wait_num		# wait until valid
	
wait_echo: 
	ldwio r17, 4(r2)
	srli r17, r17, 16 
	beq r17, r0, wait_echo		# if wpspace == 0, wait
	
	stwio r20, 0(r2)				# echo back the character
	
	bne r5, r20, wait_num 		# if not enter, 
	
	
	addi r20, r20, -48          # convert ASCII to digit
	add r3, r3, r20
	
write_str_total:

    ldb     r9, 0(r18)			# r16 = read next character from STR_PROMPT
    addi    r18, r18, 1			# advance pointer in STR_PROMPT
    beq     r9, r0, divide_loop		# if we read null character, we're done

wait_total:
	ldwio	r17, 4(r2)			# read the control register to read WSPACE
	srli	r17, r17, 16		# get WSPACE
	beq		r17, r0, wait_total		# wait until there is space

    stwio   r9, 0(r2)			# write character (r16)
    br		write_str_total     # repeat for the next character
	
	

divide_loop:
    beq r3, r0, print_loop

    # get remainder (r3 % 10) = current last digit
    divu r6, r3, r10         # r6 = r3 / 10
    mul r7, r6, r10         # r7 = (r3/10) * 10
    sub r8, r3, r7           # r8 = r3 - (r3/10)*10 = remainder

    addi r8, r8, 48          # convert to ASCII

    addi sp, sp, -4          # push onto stack
    stw r8, 0(sp)

    mov r3, r6               # r3 = r3 / 10, go again
    br divide_loop

print_loop:
    # check if stack is empty (compare sp to original sp)
    beq sp, r22, done        # r15 = saved original sp before loop

    ldw r4, 0(sp)            # pop digit
    addi sp, sp, 4

wait_space:
    ldwio r17, 4(r2)
    srli r17, r17, 16
    beq r17, r0, wait_space  # wait for wspace

    stwio r4, 0(r2)          # send digit
    br print_loop

done:
	break

.data
STR_PROMPT: .string "Enter number:"
STR_TOTAL:  .string "Total:"
